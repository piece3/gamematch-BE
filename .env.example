# Copy to .env. Never commit real credentials.
ENVIRONMENT=development

DATABASE_URL=postgresql+psycopg2://gamematch:gamematch@localhost:5432/gamematch
SECRET_KEY=replace-with-at-least-32-random-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

ALLOWED_EMAIL_DOMAIN=jnu.ac.kr
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24
EMAIL_RESEND_COOLDOWN_SECONDS=60
APP_BASE_URL=http://127.0.0.1:8000
EMAIL_DEV_MODE=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Game Match

CORS_ORIGINS=http://localhost:5173,https://simulooker.github.io

RIOT_API_KEY=
RIOT_PLATFORM=kr
RIOT_REGIONAL=asia
